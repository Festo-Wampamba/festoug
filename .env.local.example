# ── Database ──────────────────────────────────────────────────────────────────
# For local Docker dev:
DATABASE_URL=postgresql://festoug:festoug_dev@localhost:5432/festoug
# For Neon (production):
# DATABASE_URL=postgresql://user:password@ep-xxxxx.region.aws.neon.tech/neondb?sslmode=require

# ── Auth.js (generate with: openssl rand -hex 32) ─────────────────────────────
AUTH_SECRET=

# ── GitHub OAuth ───────────────────────────────────────────────────────────────
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── Google OAuth ──────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── EmailJS (server-side only — keys never exposed to client) ────────────────
EMAILJS_SERVICE_ID=
EMAILJS_TEMPLATE_ID=
EMAILJS_USER_ID=
EMAILJS_PRIVATE_KEY=

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Resend (Password Reset Emails)
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_FROM_EMAIL=noreply@yourdomain.com
