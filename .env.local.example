# ── Database ──────────────────────────────────────────────────────────────────
# For local Docker dev:
DATABASE_URL=postgresql://festoug:festoug_dev@localhost:5432/festoug
# For Neon (production):
# DATABASE_URL=postgresql://user:password@ep-xxxxx.region.aws.neon.tech/neondb?sslmode=require

# ── Auth.js ────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
AUTH_SECRET=
# Set to your production domain (e.g. https://festoug.com)
NEXTAUTH_URL=http://localhost:3000
# Required on some hosting platforms (Vercel sets this automatically)
AUTH_TRUST_HOST=true

# ── GitHub OAuth ───────────────────────────────────────────────────────────────
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── Google OAuth ──────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── EmailJS (server-side only — keys never exposed to client) ────────────────
EMAILJS_SERVICE_ID=
EMAILJS_TEMPLATE_ID=
EMAILJS_USER_ID=
EMAILJS_PRIVATE_KEY=

# ── OpenRouter AI (portfolio chatbot) ─────────────────────────────────────────
# Get your key at https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── LemonSqueezy (payments) ───────────────────────────────────────────────────
# Get from https://app.lemonsqueezy.com/settings/api
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_STORE_ID=
# Webhook secret from https://app.lemonsqueezy.com/settings/webhooks
LEMONSQUEEZY_WEBHOOK_SECRET=

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Resend (password reset emails) ────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_FROM_EMAIL=noreply@yourdomain.com
