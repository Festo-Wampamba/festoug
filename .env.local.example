# ── Database ──────────────────────────────────────────────────────────────────
# For local Docker dev:
DATABASE_URL=postgresql://festoug:festoug_dev@localhost:5432/festoug
# For Neon (production):
# DATABASE_URL=postgresql://user:password@ep-xxxxx.region.aws.neon.tech/neondb?sslmode=require

# ── Better Auth ───────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=
# Base URL of the app (e.g. https://festoug.com in production)
BETTER_AUTH_URL=http://localhost:3000

# ── GitHub OAuth ───────────────────────────────────────────────────────────────
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── Google OAuth ──────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── EmailJS (server-side only — keys never exposed to client) ────────────────
EMAILJS_SERVICE_ID=
EMAILJS_TEMPLATE_ID=
EMAILJS_USER_ID=
EMAILJS_PRIVATE_KEY=

# ── OpenRouter AI (portfolio chatbot) ─────────────────────────────────────────
# Get your key at https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── LemonSqueezy (payments) ───────────────────────────────────────────────────
# Get from https://app.lemonsqueezy.com/settings/api
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_STORE_ID=
# Webhook secret from https://app.lemonsqueezy.com/settings/webhooks
LEMONSQUEEZY_WEBHOOK_SECRET=
# Variant IDs for the annual plans (billing is annual-only)
LS_VARIANT_BASIC_ANNUAL=
LS_VARIANT_PRO_ANNUAL=

# ── Cloudinary (media uploads) ────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Bearer token guarding cron endpoints — generate with: openssl rand -hex 32
CRON_SECRET=

# ── Resend (password reset emails) ────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_FROM_EMAIL=noreply@yourdomain.com
# Where admin notification emails are sent (falls back to a default if unset)
ADMIN_NOTIFICATION_EMAIL=
